{
  "name": "cuelume",
  "version": "0.1.1",
  "description": "Curated interaction sounds for the web — synthesized live with zero runtime dependencies.",
  "keywords": [
    "web-audio",
    "sound",
    "ui-sounds",
    "sound-effects",
    "interaction-feedback",
    "interface-sounds",
    "hover",
    "click",
    "synthesis"
  ],
  "license": "MIT",
  "author": "Daniel Belyi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Danilaa1/cuelume.git"
  },
  "bugs": {
    "url": "https://github.com/Danilaa1/cuelume/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc",
    "test": "npm run build && node --test",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
